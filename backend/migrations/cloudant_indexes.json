        "index": { "fields": ["shop", "kind", "ts_unix_ms"] }
      }
    },
    {
      "db": "audit_log",
      "index": {
        "name": "by-shop-actor-time",
        "type": "json",
        "index": { "fields": ["shop", "actor", "ts_unix_ms"] }
