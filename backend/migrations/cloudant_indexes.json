{
  "comment": "Mango indexes for the Helios Cloudant collections. Applied by apply_indexes.py. Each entry is { db: <short>, index: <Cloudant create-index payload> }. Field selection follows the queries actually issued by app/services/* and app/api/* (audit code uses ts_unix_ms, not created_at).",
  "indexes": [
    {
      "db": "regions",
      "index": {
        "name": "by-shop-kind-name",
        "type": "json",
        "index": { "fields": ["shop", "kind", "name"] }
      }
    },
    {
      "db": "regions",
      "index": {
        "name": "by-shop-kind-tier",
        "type": "json",
        "index": { "fields": ["shop", "kind", "tier"] }
      }
    },
    {
      "db": "jcl_artifacts",
      "index": {
        "name": "by-shop-kind-region-name",
        "type": "json",
        "index": { "fields": ["shop", "kind", "region", "name"] }
      }
    },
    {
      "db": "jcl_artifacts",
      "index": {
        "name": "by-shop-kind-region-score",
        "type": "json",
        "index": { "fields": ["shop", "kind", "region", "current_confidence_score"] }
      }
    },
    {
      "db": "findings",
      "index": {
        "name": "by-shop-region-state-severity",
        "type": "json",
        "index": { "fields": ["shop", "subject.region", "state", "severity"] }
