# Helios frontend — copy to .env.local and edit.
# These are exposed to the client (NEXT_PUBLIC_*) so do not put secrets here.

# API base URL. Empty + NEXT_PUBLIC_USE_MSW=true → talk to MSW handlers in-browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# When true, the app boots with Mock Service Worker intercepting every fetch.
# Use this to demo without the backend running.
NEXT_PUBLIC_USE_MSW=true

# When the static export is published to GitHub Pages.
# GITHUB_PAGES=true PAGES_BASE_PATH=/Helios npm run build
GITHUB_PAGES=false
PAGES_BASE_PATH=/Helios
