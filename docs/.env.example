# Helios — Environment Variables Template
#
# Copy this file to .env and fill in your values. NEVER commit .env.
# See docs/INSTALLATION.md §4 and docs/TOOLS_AND_SERVICES.md.

# ─── IBM Cloud ────────────────────────────────────────────────────────────────

# Generate at https://cloud.ibm.com/iam/apikeys (Manager scope on Cloudant + watsonx)
IBM_CLOUD_API_KEY=

# Region for all IBM Cloud services. Stick to one region; mixing causes egress.
IBM_CLOUD_REGION=us-south

# ─── Cloudant ─────────────────────────────────────────────────────────────────

# From `ibmcloud resource service-key helios-cloudant-key` → "url" and "apikey"
CLOUDANT_URL=
CLOUDANT_APIKEY=

# Database name prefix. Production uses "helios_". Demos use "helios_demo_".
CLOUDANT_DB_PREFIX=helios_

# ─── watsonx.ai ───────────────────────────────────────────────────────────────

# From watsonx project → Settings → Services & integrations
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_APIKEY=

# Models — leave defaults unless you have a reason to change
WATSONX_CODE_MODEL=ibm/granite-code-8b-instruct
WATSONX_CHAT_MODEL=ibm/granite-3-8b-instruct

# Set to 1 for offline development. Returns canned responses; demo stays
# pixel-identical with no internet. See docs/INSTALLATION.md §10.
HELIOS_MOCK_WATSONX=0

# ─── Auth (hackathon bootstrap) ───────────────────────────────────────────────

# Generate fresh: openssl rand -hex 32
JWT_SECRET=

# Token lifetime for seeded users
JWT_TTL_SECONDS=86400

# ─── GitHub ───────────────────────────────────────────────────────────────────

# Classic PAT with: repo, read:org, read:project. Bob's MCP server inherits this.
# Scope minimization matters — see docs/SECURITY.md.
GITHUB_PERSONAL_ACCESS_TOKEN=

# ─── Frontend ─────────────────────────────────────────────────────────────────

# Where the frontend should hit the backend. Override in CI for deployed builds.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws/queue

# ─── Backend ──────────────────────────────────────────────────────────────────

# CORS origins (comma-separated). Add your deployed frontend URL here.
CORS_ORIGINS=http://localhost:3000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── Bob IDE (used by the shared .bob/mcp.json) ───────────────────────────────

# Absolute path to the repo root. Bob substitutes this in mcp.json.
PROJECT_ROOT=

# ─── Optional: Code Engine deployment (only needed for `make deploy`) ─────────

CODE_ENGINE_PROJECT=helios-prod
CODE_ENGINE_APP_NAME=helios-backend
IBM_CLOUD_REGISTRY=us.icr.io/helios
