# Helios — per-developer environment template
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# this file (`.env.example`) is committed so both developers know what to set.
#
# Bob IDE and Claude Code both inherit these vars from the shell that launched
# them. See docs/MCP_SETUP.md § "Per-developer .env" for the auto-load snippet.

# --- Repo root (absolute path on this machine) -----------------------------
# Used by the filesystem MCP and the helios-corpus MCP to scope reads.
PROJECT_ROOT=

# --- GitHub --------------------------------------------------------------
# Classic PAT, scopes: repo, read:org, read:project. NO delete_repo, NO admin:*.
# Generate at https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- IBM Cloud -----------------------------------------------------------
# Generate at https://cloud.ibm.com/iam/apikeys
IBM_CLOUD_API_KEY=
IBM_CLOUD_REGION=us-south
CODE_ENGINE_PROJECT_ID=

# --- Cloudant ------------------------------------------------------------
# From your Cloudant Lite service credentials in IBM Cloud.
CLOUDANT_URL=
CLOUDANT_APIKEY=

# --- watsonx.ai ----------------------------------------------------------
# From your watsonx.ai project. Use Granite Code 8B; banned models are listed
# in CLAUDE.md / AGENTS.md.
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_APIKEY=
