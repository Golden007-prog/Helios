# Helios — comprehensive ignore list.
#
# Sections are numbered to match docs/BANKDEMO_INTEGRATION.md and the team
# discipline in AGENTS.md hard rule #3 (never commit .env, CLAUDE.md, or
# .bob/sessions/). When in doubt, prefer to ignore: lockfiles, the LICENSE,
# and a small set of intentionally-committed seed data are listed under the
# explicit negations at the bottom.
#
# Order matters: include patterns first, then negations. Adding a new
# section? Append it under a numbered header and document why each pattern
# is here so the next dev doesn't second-guess.


# ============================================================
# 1. Python build & cache artifacts
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
backend/.coverage
htmlcov/
coverage.xml
.hypothesis/
.tox/
.nox/
pip-log.txt
pip-delete-this-directory.txt
.python-version


# ============================================================
# 2. Python virtual environments
# ============================================================
.venv/
venv/
env/
ENV/
.venv-*
virtualenv/


# ============================================================
# 3. Node / Next.js / frontend tooling
# ============================================================
# Lockfiles are intentionally committed — see explicit negations at bottom.
node_modules/
.next/
out/
.turbo/
.swc/
.cache/
.parcel-cache/
*.tsbuildinfo
next-env.d.ts
.vercel/
.npm/
.yarn/
.pnp.*
yarn-error.log*
npm-debug.log*
pnpm-debug.log*


# ============================================================
# 4. Test outputs
# ============================================================
playwright-report/
test-results/
.playwright/
blob-report/
coverage/
frontend/coverage/
.nyc_output/
lcov.info
junit.xml
/storybook-static/


# ============================================================
# 5. IDE / editor / OS
# ============================================================
# .vscode/ is currently untracked; if the team decides to share parts of
# it (e.g., settings.json that maps schemas to .bob/mcp.json), un-ignore
# the specific files in the negations block at the bottom.
.vscode/*
.vscode/settings.local.json
.vscode/.ropeproject
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
ehthumbs.db
*.lnk


# ============================================================
# 6. Microsoft Office temp & lock files
# ============================================================
~$*.docx
~$*.xlsx
~$*.pptx
*.tmp


# ============================================================
# 7. Bob IDE & Claude Code artifacts
# ------------------------------------------------------------
# AGENTS.md hard rule #3: never commit .env, CLAUDE.md, .bob/sessions/.
# .bob/mcp.json IS committed (shared MCP config) — see negations.
# bob_sessions/{golden,sayan}/*.md (non-draft) ARE committed — those are
# the audit-trail exports judges read. Only *.draft.md is local.
# ============================================================
.claude/
.claude.json
CLAUDE.md
CLAUDE.local.md
.bob/sessions/
.bob/cache/
.bob/state/
.bob/auth/
.bob/.cache/
.bob/*.log
bob_findings/
bob_sessions/golden/*.draft.md
bob_sessions/sayan/*.draft.md
.anthropic/
claude-*.log


# ============================================================
# 8. Secrets & credentials
# ------------------------------------------------------------
# .env.example IS committed (template for both devs). All other .env.*
# variants are local. mfsecrets_login.json is anchored to repo root only
# — the same filename appears under test dataset/ (BankDemo) where it must
# remain readable for parsing.
# ============================================================
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.yaml
secrets.yml
*.token
*.apikey
/mfsecrets_login.json


# ============================================================
# 9. Logs & runtime state
# ============================================================
*.log
logs/
log/
*.pid
*.seed
*.pid.lock


# ============================================================
# 10. Local databases & artifacts
# ============================================================
*.db
*.sqlite
*.sqlite3
*.db-journal
local-cloudant/
.cloudant-cache/


# ============================================================
# 11. Docker / container local overrides
# ============================================================
docker-compose.override.yml
docker-compose.override.yaml
.dockerignore.local


# ============================================================
# 12. Backup / merge / patch files
# ============================================================
*.bak
*.backup
*.orig
*.rej
*.diff
.#*
*#
.env.example.bak


# ============================================================
# 13. Helios project-specific
# ------------------------------------------------------------
# test dataset/  — Rocket BankDemo, see docs/BANKDEMO_INTEGRATION.md.
#                  Read-only source; never committed.
# bankdemo-derived/  — generated by seed_demo from the gitignored dataset;
#                      regeneratable, no need to commit.
# abend_examples/    — hand-crafted from BankDemo programs (also derived).
# bench/results/     — local benchmark JSON; keep the .gitkeep.
# docs/ASSUMPTIONS.md — local notes between sessions; promote into a
#                       permanent doc once a question is answered.
# ============================================================
test dataset/
shared/sample-corpus/bankdemo-derived/
shared/sample-corpus/abend_examples/
bench/results/*.json
docs/ASSUMPTIONS.md
docs/CALIBRATION_REPORT.md
docs/PARSER_GAPS.md
docs/drafts/
.helios-cache/
outputs/

# Helios convention: any *.local.json is per-developer override (e.g., a
# .bob/mcp.local.json that adds a personal server). Never commit.
*.local.json


# ============================================================
# 14. Build / archive artifacts
# ============================================================
# No checked-in zip/tar.gz fixtures today; if any get added, switch to
# a path-specific ignore instead of these globs.
*.zip
*.tar.gz


# ============================================================
# 15. Test sources (kept local — not part of the repo audit trail)
# ------------------------------------------------------------
# Per team decision: test files do not ship to GitHub. They still run
# locally (the patterns ignore git tracking, not pytest/vitest discovery).
# Covers Python (test_*.py, *_test.py, tests/), JS/TS (*.test.{ts,tsx,js,jsx},
# *.spec.{ts,tsx,js,jsx}, __tests__/), e2e (e2e/, playwright/), and the
# shell test runners at repo root.
# ============================================================
# Python conventions
tests/
test_*.py
*_test.py
conftest.py

# JS / TS conventions
*.test.ts
*.test.tsx
*.test.js
*.test.jsx
*.spec.ts
*.spec.tsx
*.spec.js
*.spec.jsx
__tests__/
__mocks__/

# End-to-end / integration
e2e/
/playwright/
playwright.config.ts
playwright.config.js

# Test setup / config that lives outside the suites above
src/test/
src/__tests__/
vitest.config.ts
vitest.config.js
vitest.setup.ts
vitest.setup.js
jest.config.ts
jest.config.js
jest.setup.ts
jest.setup.js

# Shell-driven test runners at repo root
test-*.ps1
test-*.sh

# Smoke / integration JSON fixtures alongside tests
audit_canonical_test_vectors.json
test_args.json


# ============================================================
# 16. Explicit negations — these MUST always be tracked
# ------------------------------------------------------------
# Order matters: negations come last so they win against any pattern above.
# Lockfiles are required for deterministic builds; the schema files and
# the seeded region/pattern YAMLs are the demo's source of truth.
# ============================================================
!.env.example
!.gitignore
!**/.gitkeep
!.pre-commit-config.yaml

# Lockfiles
!frontend/package-lock.json
!frontend/pnpm-lock.yaml
!frontend/yarn.lock
!backend/uv.lock
!backend/poetry.lock

# Licensing & legal
!LICENSE
!NOTICE.md
!docs/LICENSE

# Seed data + schemas (committed by design)
!shared/schemas/*.json
!shared/sample-corpus/regions/*.yaml
!shared/sample-corpus/abend_patterns/*.yaml
!bench/results/.gitkeep

# Bob shared MCP config (per AGENTS.md / docs/MCP_SETUP.md)
!.bob/mcp.json
